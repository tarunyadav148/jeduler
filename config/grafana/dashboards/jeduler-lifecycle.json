{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "State Transition Rates",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(jeduler_state_transitions_total[5m]) * 60",
          "legendFormat": "{{from}} → {{to}} ({{jobName}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 50 },
          "unit": "opm"
        },
        "overrides": []
      }
    },
    {
      "title": "Heartbeat Failure Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(jeduler_heartbeat_failures_total[5m])) * 60",
          "legendFormat": "Failures/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "title": "Total Jobs Processed",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "sum(jeduler_state_transitions_total{to=\"SUCCESSFUL\"})",
          "legendFormat": "Successful"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "title": "Total Failures",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum(jeduler_state_transitions_total{to=\"FAILED\"}) + sum(jeduler_state_transitions_total{to=\"FAILED_BY_SCHEDULER\"})",
          "legendFormat": "Failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "title": "Scheduling Algorithm Duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(jeduler_scheduling_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 - {{jobName}}"
        },
        {
          "expr": "histogram_quantile(0.95, rate(jeduler_scheduling_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 - {{jobName}}"
        },
        {
          "expr": "histogram_quantile(0.50, rate(jeduler_scheduling_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 - {{jobName}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["jeduler"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "title": "Jeduler - Job Lifecycle",
  "uid": "jeduler-lifecycle"
}
